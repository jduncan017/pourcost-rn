{
  "expo": {
    "name": "PourCostRN",
    "slug": "PourCost-RN",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-dark.png",
    "scheme": "pourcostrn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshuaduncan.pourcostdev",
      "infoPlist": {
        "CFBundleDisplayName": "PourCost"
      },
      "icon": {
        "dark": "./assets/images/ios-dark.png",
        "light": "./assets/images/ios-light.png",
        "tinted": "./assets/images/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ios-dark.png",
        "backgroundColor": "#0B1120"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.twentyninelabs.pourcost"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "addGeneratedScheme": false
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
